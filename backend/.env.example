# ── LLM ──────────────────────────────────────────────────────────────────────
# 通用 OpenAI 兼容配置（OpenAI / 代理 / 火山方舟豆包等均走此处）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# 官方 OpenAI 可留空；火山方舟示例: https://ark.cn-beijing.volces.com/api/v3
OPENAI_BASE_URL=
# 模型名或接入点名（方舟见控制台）
LLM_MODEL=doubao-seed-2-0-mini-260428
# 向量：openai=云端兼容 embedding；local=本机 BGE（具体权重名在 config.py 常量里）
EMBEDDING_PROVIDER=local
# 仅 EMBEDDING_PROVIDER=local：auto / cpu / mps / cuda
EMBEDDING_DEVICE=auto

# ── 存储 ──────────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
SQLITE_PATH=./data/fomo.db

# ── 通知推送（留空则不推送） ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
WECOM_WEBHOOK_URL=

# ── 服务配置 ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
# 美东时区定时任务时间（24h格式）
PRE_MARKET_HOUR=8
PRE_MARKET_MINUTE=30
POST_MARKET_HOUR=16
POST_MARKET_MINUTE=30

# ── 热门股：计分窗口 = 最近 N 个美股交易日；HOT_POOL_WINDOW_DAYS 亦用于简讯清理（自然日滚动）──
HOT_POOL_WINDOW_DAYS=7
HOT_POOL_MAX_SIZE=15
