# ── Postgres（必选） ─────────────────────────────────────────────────────────
# 任选其一：整串 URL **或** 下面 DB_*（留空分项则走 config.py 默认值）
DATABASE_URL=

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=fomo
DB_SSLMODE=

# ── 网关密钥（必选；方舟/OpenAI 等） ───────────────────────────────────────
OPENAI_API_KEY=

# ── Telegram（可选） ───────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# WECom：
# WECOM_WEBHOOK_URL=

# ── 模型：每项都是「Base URL + 模型 ID」 ────────────────────────────────────
# 仍可兼容旧变量：OPENAI_BASE_URL、LLM_MODEL、ARK_EMBEDDING_MODEL。

# 1) 对话（主链路 / 简报等）
LLM_CHAT_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_CHAT_MODEL=doubao-seed-2-0-mini-260428

# 2) 向量：local=本机 BGE；openai=兼容 /embeddings；ark=方舟多模态官方 SDK（见下）
EMBEDDING_PROVIDER=ark
# ark：一般留空——SDK 默认 https://ark.cn-beijing.volces.com/api/v3 ，无需单独的 Embedding URL
ARK_API_BASE_URL=
# 兼容旧配置：以往若填整条 …/embeddings/multimodal，仍可用此项，会自动归一成网关根路径
ARK_EMBEDDINGS_URL=
LLM_EMBED_MODEL=doubao-embedding-vision-251215
# 仅 openai 兼容路径时使用（LLM_EMBED_BASE_URL）；ark 不向量化读此项
LLM_EMBED_BASE_URL=

# 3) 轻量（情绪 / 热点；不配则等同于对话）
LLM_LITE_BASE_URL=
LLM_LITE_MODEL=

# 临时：全量重建投研向量前，在请求头 X-Reembed-Secret 中携带与本值一致的随机串
RESEARCH_REEMBED_SECRET=
