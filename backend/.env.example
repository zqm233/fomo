# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=                          # 留空使用官方地址；可填代理 URL
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ── 存储 ──────────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
SQLITE_PATH=./data/fomo.db

# ── 爬虫 ──────────────────────────────────────────────────────────────────────
# x-tweet-fetcher 安装根目录（绝对路径），留空则禁用 Twitter 爬取
TWITTER_FETCHER_PATH=
# 微信公众号爬虫 Cookie（可选，用于需要登录的接口）
WECHAT_COOKIE=

# ── 通知推送（留空则不推送） ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
WECOM_WEBHOOK_URL=

# ── 服务配置 ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
# 美东时区定时任务时间（24h格式）
PRE_MARKET_HOUR=8
PRE_MARKET_MINUTE=30
POST_MARKET_HOUR=16
POST_MARKET_MINUTE=30
